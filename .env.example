# Futurematch AI — recommended production values (PythonAnywhere Web → Environment variables)
# Copy relevant keys to your host env or load via WSGI. Reload web app after changes.

OPENAI_API_KEY=

# Models
AI_MAIN_MODEL=gpt-4o
AI_FAST_MODEL=gpt-4o-mini
AI_RUNTIME=responses

# Token budgets (keep under OpenAI org TPM limit, e.g. 30000)
AI_MAX_INPUT_TOKENS=20000
AI_TPM_BUDGET=26000
AI_MAX_OUTPUT_TOKENS=450
AI_MAX_TOOL_ITERATIONS=3
# Tool-deciding turns pin a low temperature for deterministic tool selection
# (empty value = use the API default). Token estimator chars/token divisor is
# tunable for Danish (legacy default 4.0).
AI_TOOL_TURN_TEMPERATURE=0.2
AI_TOKEN_CHARS_PER_TOKEN=4.0
# Optional token/recall tuning (default off — enable after an eval baseline confirms no regression)
AI_TRIM_TOOL_DESCRIPTIONS=off
AI_GROUNDING_DECOMPOUND=off

# Resilience
AI_RATE_LIMIT_RETRY_SECONDS=2.5
AI_RATE_LIMIT_COOLDOWN_SECONDS=90
AI_OPENAI_TIMEOUT_SECONDS=40

# Context
AI_FEW_SHOT=compact
AI_SUMMARY_MODE=rules
AI_TOOL_ROUTER_V2=1

# AI Tooler 2 — platform-control tools + confirm/progress UI (master kill-switch, default off)
AI_TOOLER2=off
# Live tool progress/finish events (existing) and final-answer capture (existing)
AI_LIVE_TOOL_EVENTS=1
AI_CAPTURE_FINAL=1

# RAG / embeddings
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=1024
AI_RAG_CROSS_ENCODER=auto
AI_RERANK_MAX_CANDIDATES=4

# Observability (optional)
AI_TRACE_SAMPLE_RATE=1
AI_WARMUP_ON_IMPORT=1

# Re-index note: after switching AI_EMBEDDING_MODEL, run app1/build_index.py once and verify sample queries.
