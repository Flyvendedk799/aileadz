# Sandbox environment — points the app at the local Dockerized MySQL.
# Loaded by run_sandbox.py. Values already exported in your shell take priority,
# so you can `export OPENAI_API_KEY=sk-...` instead of editing this file.

# --- Local sandbox DB (docker-compose.yml) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=fm
MYSQL_PASSWORD=fm
MYSQL_DB=futurematch_sandbox

# Force schema creation on boot (ignore the prod sync-TTL stamp).
ENTERPRISE_TABLE_SYNC_FORCE=1

# Skip the slow import-time RAG warmup; it warms lazily on the first chat call.
AI_WARMUP_ON_IMPORT=0

# Required for the AI to actually answer. Put your real key here OR export it.
OPENAI_API_KEY=
AI_MAIN_MODEL=gpt-4o
AI_FAST_MODEL=gpt-4o-mini

# Local server port for ./sandbox.sh run
SANDBOX_PORT=5001
SANDBOX=1
